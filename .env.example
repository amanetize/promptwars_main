# Copy this file to .env and fill in your real key. Never commit .env.
OPENROUTER_API_KEY=

# Ordered fallback chain (comma-separated, no spaces needed). Tried in order;
# on failure (rate limit, quota exhausted, model down) the next one is tried
# automatically. tencent/hy3:free is a free promo model (see README for the
# expiry note) — google/gemini-2.5-flash is the paid fallback — openrouter/free
# is OpenRouter's own auto-picking free-model router, used as a last resort.
OPENROUTER_MODELS=tencent/hy3:free,google/gemini-2.5-flash,openrouter/free

PORT=3000
